<Window
    x:Class="PresenterBETA.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BETA VERSION"
    Width="1000"
    Height="700"
    Background="#1E2328">

    <Window.Resources>
        <!-- Modern Icon Style -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Tooltip Label Style -->
        <Style x:Key="HoverTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D3238" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E444D" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="BottomRow" Height="220" MinHeight="30" MaxHeight="520" />
        </Grid.RowDefinitions>

        <!-- 1. TOP SECTION (THE SLIDE WORKSPACE) -->
        <Grid Grid.Row="0" Background="#282C34">
            <!-- Dark Workspace Background -->

            <!-- The Slide Surface -->
            <Border
                x:Name="SlideSurface"
                Width="800"
                Height="450"
                Margin="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#D1D1D1"
                BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Direction="315" Opacity="0.4" ShadowDepth="5" />
                </Border.Effect>

                <Canvas x:Name="EditorCanvas" Background="Transparent" ClipToBounds="True" />
            </Border>

            <!-- Add Element Button (FAB) -->
            <Button 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="20"
                Width="45"
                Height="45"
                Background="#0078D4"
                Click="OnAddBoxClick">
                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE710;" FontSize="20" Foreground="White"/>
            </Button>
        </Grid>

        <!-- 2. RESIZER -->
        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#101317" />

        <!-- 3. BOTTOM SECTION -->
        <Grid Grid.Row="2" x:Name="BottomContentGrid" Background="#FF181B1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" BorderBrush="#4A5668" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="10" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button ToolTip="Save">
                            <TextBlock Style="{StaticResource IconStyle}" Text="&#xE74E;" />
                        </Button>
                        <Button ToolTip="Delete">
                            <TextBlock Style="{StaticResource IconStyle}" Text="&#xE74D;" />
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Slides List" Foreground="#4A5668" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10" />
                </Grid>
            </Border>

            <!-- PREVIEW AREA -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="ViewContainer" Margin="10" VerticalAlignment="Center">
                    <Button Width="160" Height="90" Margin="10" Click="OnCreateViewClick" BorderBrush="#4A5668" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Add Slide" FontSize="10" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>