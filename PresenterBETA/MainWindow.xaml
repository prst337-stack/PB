<Window
    x:Class="PresenterBETA.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BETA VERSION"
    Width="900"
    Height="550"
    Background="#1E2328">

    <Window.Resources>
        <!-- Icon Style -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Hover Text Style -->
        <Style x:Key="HoverTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D3238" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E444D" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition
                x:Name="BottomRow"
                Height="220"
                MinHeight="25"
                MaxHeight="450" />
        </Grid.RowDefinitions>

        <!-- 1. TOP SECTION -->
        <Border
            Grid.Row="0"
            Margin="15"
            Background="White"
            CornerRadius="5">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="Black"
                Text="Main Display Area" />
        </Border>

        <!-- 2. RESIZER -->
        <GridSplitter
            Grid.Row="1"
            Height="3"
            HorizontalAlignment="Stretch"
            Background="#101317"
            ResizeBehavior="PreviousAndNext" />

        <!-- 3. BOTTOM SECTION (MAIN CONTENT) -->
        <Grid
            x:Name="BottomContentGrid"
            Grid.Row="2"
            Background="#FF181B1E">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <!-- Hide UI at Minimum Height -->
                        <DataTrigger Binding="{Binding ActualHeight, ElementName=BottomContentGrid}" Value="25">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <!-- Hide UI at Maximum Height -->
                        <DataTrigger Binding="{Binding ActualHeight, ElementName=BottomContentGrid}" Value="450">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border
                Grid.Column="0"
                BorderBrush="#4A5668"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,10,0,20"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button ToolTip="Create">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE710;" />
                                <TextBlock Style="{StaticResource HoverTextStyle}" Text="Create" />
                            </StackPanel>
                        </Button>
                        <Button ToolTip="Save">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE74E;" />
                                <TextBlock Style="{StaticResource HoverTextStyle}" Text="Save" />
                            </StackPanel>
                        </Button>
                        <Button ToolTip="Delete">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconStyle}" Text="&#xE74D;" />
                                <TextBlock Style="{StaticResource HoverTextStyle}" Text="Delete" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Foreground="#4A5668"
                        Text="File Tree View" />
                </Grid>
            </Border>

            <!-- PREVIEW (Kept exactly as requested) -->
            <Border Grid.Column="1">
                <Button
                    Width="173"
                    Height="110"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            FontSize="24"
                            Style="{StaticResource IconStyle}"
                            Text="&#xE710;" />
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{StaticResource HoverTextStyle}"
                            Text="View" />
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- 4. HINT: DRAG UP (Visible at MinHeight 25) -->
        <Border
            Grid.Row="2"
            Background="#1E2328"
            IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActualHeight, ElementName=BottomContentGrid}" Value="25">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.6"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    FontFamily="Segoe MDL2 Assets"
                    Foreground="#4A5668"
                    Text="&#xE70E;" />
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#4A5668"
                    Text="DRAG UP TO VIEW CONTROLS" />
            </StackPanel>
        </Border>

        <!-- 5. HINT: DRAG DOWN (Visible at MaxHeight 450) -->
        <Border
            Grid.Row="2"
            Background="#1E2328"
            IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActualHeight, ElementName=BottomContentGrid}" Value="450">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.6"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    FontFamily="Segoe MDL2 Assets"
                    Foreground="#4A5668"
                    Text="&#xE70D;" />
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#4A5668"
                    Text="DRAG DOWN TO VIEW MAIN DISPLAY" />
            </StackPanel>
        </Border>

    </Grid>
</Window>